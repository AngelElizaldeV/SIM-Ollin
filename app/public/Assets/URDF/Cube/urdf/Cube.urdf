<?xml version="1.0" ?>
<robot name="cube">
  <link name="cube_link">
    <inertial>
      <origin xyz="0 0 0" />
      <mass value="1.0"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" />
      <geometry>
        <box size="0.0254 0.0254 0.0254"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" />
      <geometry>
        <box size="0.0254 0.0254 0.0254"/>
      </geometry>
    </collision>
  </link>
</robot>
